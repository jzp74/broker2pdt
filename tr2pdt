@dataclass()
class DataClassBase:
	"""
	This base dataclass is solely to define the 2 functions below
	"""
	@classmethod
	def get_field_names(cls):
		return [f.name for f in fields(cls)]

	def get_field_values(self):
		return [getattr(self, f.name) for f in fields(self)]

