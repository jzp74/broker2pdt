def print_info(s):
	"""
	Displays extra info (when the argument --info has been provided by the user)

	Args:
		s: string to display
	"""
	if _info_on:
		print(f"{s}", flush=True)


def tr_fixfloat(s):
	"""
	Converts a string to a float

	Args:
		s: string containing numbers or the word Kostenlos
	"""
	if s == None:
		return 0.0
	return float(s.replace(".", "").replace(",", ".").replace("€", "").rstrip())


def tr_fixfloat(f):
	"""
	Converts None to 0.0 and a negative number to a positive number

	Args:
		f: float containing None, a positive or negative float
	"""
	if f == None:
		return 0.0
	return abs(f)

def add_tr_expense(broker: str, dt: str, tm: str, description: str, value: float, currency: str = "EUR"):
	"""
	Add a Trade Republic expense if it is not already present in the current PDT workbook.

	Args:
		broker:	Name of the broker (e.g., "Trade Republic")
		dt: Date as a string in "YYYY-MM-DD" format
		tm:	Time as a string in "HH:MM" format
		description: Description of the expense (e.g., "Gebühr", "Steuer")
		value: Expense value (positive number)
		currency: Currency code (default is "EUR")
	"""

	#print_info("adding broker expense")
	expense = ExpenseDetails(
		broker=broker,
		date=dt,
		time=tm,
		description=description,
		value=round(value, 2),
		currency=currency
	)

	# Deduplication and storage
	if expense not in pdt_workbook_expenses:
		print(f"   storing    EXPENSE  at {dt} for {broker} of ({currency} {value})")
		tr_expenses.append(expense)
	else:
		print_info("   EXPENSE was already in PDT workbook")


def add_tr_booking(broker: str, dt: str, tm: str, action: str, value: float, currency: str = "EUR"):
	"""
	Add a Trade Republic cash booking if it is not already present in the current PDT workbook.

	Args:
		broker: Name of the broker
		dt: Date as "YYYY-MM-DD"
		tm: Time as "HH:MM"
		action: Action label (e.g., "Dividend", "Deposit")
		value: Booking amount (positive or negative)
		currency: Currency code (default is "EUR")
	"""

	#print("adding broker booking")
	booking = BookingDetails(
		broker=broker,
		date=dt,
		time=tm,
		action=action,
		value=round(value, 2),
		currency=currency,
	)

	# Deduplication and storage
	if booking not in pdt_workbook_bookings:
		print(f"   storing   BOOKING   at {dt} to {broker} of {currency} {value}")
		tr_bookings.append(booking)
	else:
		print_info("   BOOKING was already in PDT workbook")


def read_tr_dividend(tx: dict, date_str: str, time_str: str):
	"""
    Parse a single Trade Republic dividend event into a DividendDetails object.

    Args:
        event: Raw event dictionary from the Trade Republic timeline.
        date_str: Date string "YYYY-MM-DD" extracted from the event timestamp.
        time_str: Time string "HH:MM" extracted from the event timestamp.
    """
	print_info("   this is a DIVIDEND of Trade Republic")

	taxes = tr_fixfloat(tx["Taxes"])
	dividend = DividendDetails(
		broker=std_broker_name,
		name=tx["Note"],
		tp=std_dividend_type,
		isin=tx["ISIN"],
		exchange=std_exchange_name,
		date=date_str,
		time=time_str,
		action=std_dividend_action,
		amount=round(tr_fixfloat(tx["Value"] - taxes), 2),
		currency="EUR"
	)

	# create an expense if taxes had to be paid
	if taxes > 0.0:
		description = f"Financial Dividend Tax for {dividend.name}"
		add_tr_expense(dividend.broker, date_str, time_str, description, taxes, dividend.currency)
		dividend.amount = dividend.amount - taxes

	# Deduplication and storage
	if dividend not in pdt_workbook_dividends:
		print(f"   storing  DIVIDEND   at {date_str} of {dividend.isin} - {dividend.name} of {dividend.currency} {dividend.amount}")
		tr_dividends.append(dividend)
	else:
		print_info("   DIVIDEND was already in PDT workbook")


def read_tr_transaction(tx: dict, date_str: str, time_str: str):
	"""
    Parse a single Trade Republic trading event into a TransactionDetails object
    and, if needed, create subordinate expense and booking lines.

    Args:
        tx:  Raw event dictionary from the Trade Republic timeline.
        date_str:   Event date in "YYYY-MM-DD" format.
        time_str:   Event time in "HH:MM" format.
	"""
	print_info("   this is a TRANSACTION of Trade Republic")

	tr = TransactionDetails(
		broker=std_broker_name,
		name=tx["Note"],
		tp=std_transaction_tp,
		isin=tx["ISIN"],
		exchange=std_exchange_name,
		date=date_str,
		time=time_str,
		action=tx["Type"],
		amount=0.0,
		value=0.0,
		currency="EUR"
	)

	# we know the amount of shares, gross sum value of the transaction and fees and taxes
	amount_of_shares = tr_fixfloat(tx["Shares"])
	gross_sum_value = tr_fixfloat(tx["Value"])
	fees = tr_fixfloat(tx["Fees"])
	taxes = tr_fixfloat(tx["Taxes"])
	# now let's calculate the net sum value
	net_sum_value = gross_sum_value - fees - taxes
	# and calculate the share value
	share_value = 1 / (amount_of_shares / net_sum_value)
	# set the correct values in TransactionDetails
	tr.amount = amount_of_shares
	tr.value = round(share_value, 2)

	# create an expense if taxes had to be paid
	if taxes > 0.0:
		description = f"Financial Transaction Tax for {tr.name}"
		add_tr_expense(tr.broker, date_str, time_str, description, taxes, tr.currency)

	# create an expense if fees had to be paid
	if fees > 0.0:
		description = f"External cost surcharge for {tr.name}"
		add_tr_expense(tr.broker, date_str, time_str, description, fees, tr.currency)

	# create a booking (one hour before the transaction) for the gross sum value
	booking_time = datetime.strptime(time_str, "%H:%M") - timedelta(hours=1)
	if booking_time < datetime.strptime("01:00", "%H:%M"):
		booking_time_str = "00:00"
	else:
		booking_time_str = booking_time.strftime("%H:%M")
	add_tr_booking(tr.broker, date_str, booking_time_str, std_booking_action, gross_sum_value, tr.currency)

	# Deduplication and storage
	if tr in pdt_workbook_transactions:
		print_info("   TRANSACTION was already in PDT workbook")
		return

	print(f"   storing TRANSACTION at {tr.date} of {tr.isin} - {tr.name} for {tr.amount} of {tr.currency} {tr.value}")
	tr_transactions.append(tr)


def read_tr_tx(tx: dict):
	"""
	Process a single Trade Republic tx entry and route it to the appropriate handler based on the Type

	Arguments:
		tx (dict): A JSON object representing a Trade Republic tx.
	"""

	print_info(f"   reading tx: at {tx["Date"]}: {tx["Type"]} €{tx["Value"]} ({tx["Note"]})")

	# Convert date to date and time strings
	dt = datetime.strptime(tx["Date"], "%Y-%m-%dT%H:%M:%S")
	date_str = dt.strftime("%Y-%m-%d")
	time_str = dt.strftime("%H:%M")

	# Dispatch event to appropriate parser based on type and subtitle
	if tx["Type"] == std_transaction_action_buy or tx["Type"] == std_transaction_action_sell:
		read_tr_transaction(tx, date_str, time_str)
	elif tx["Type"] == std_dividend_id:
		read_tr_dividend(tx, date_str, time_str)


def import_worksheet(ws, dataclass_type):
	"""
	Import data from a worksheet into the appropriate global list by parsing rows
	into dataclass instances.

	Arguments:
		ws (openpyxl.worksheet): The worksheet to be imported.
		dataclass_type (type): The dataclass to instantiate from the worksheet rows.
	"""

	# Extract all rows from the worksheet, first row is assumed to be the header
	rows = list(ws.iter_rows(values_only=True))
	header = rows[0]
	data_rows = rows[1:]

	# Convert each data row to a dictionary and instantiate dataclass
	for row in data_rows:
		data_dict = dict(zip(header, row))
		# print_info(f"found dict {data_dict}")

		# Create dataclass instance
		obj = dataclass_type(**data_dict)

		# Append to correct global list based on dataclass type
		if dataclass_type is TransactionDetails:
			pdt_workbook_transactions.append(obj)
		elif dataclass_type is DividendDetails:
			pdt_workbook_dividends.append(obj)
		elif dataclass_type is BookingDetails:
			pdt_workbook_bookings.append(obj)
		elif dataclass_type is ExpenseDetails:
			pdt_workbook_expenses.append(obj)


def import_from_pdt(folder_name, file_name):
	"""
	Imports data from an existing PDT Excel workbook into memory.
	Populates the global lists for transactions, dividends, bookings, and expenses.

	Args:
		folder_name (str): The folder containing the Excel file.
		file_name (str): The name of the Excel file without the ".xlsx" extension.
	"""
	file_path = os.path.join(folder_name, f"{file_name}.xlsx")

	# Check if the file exists
	if not os.path.exists(file_path):
		print(f"{file_path} does not seem to exist")
		return

	# Try opening the file in append mode to check if it's writable (i.e., not open in Excel)
	try:
		with open(file_path, 'a+b'):
			pass

		# Load the workbook and import all worksheets into corresponding lists
		wb = load_workbook(file_path)

		import_worksheet(wb["Transactions"], TransactionDetails)
		import_worksheet(wb["Dividends"], DividendDetails)
		import_worksheet(wb["Bookings"], BookingDetails)
		import_worksheet(wb["Expenses"], ExpenseDetails)

		# Summary of imported data
		t_str = f"{len(pdt_workbook_transactions)} transactions"
		d_str = f"{len(pdt_workbook_dividends)} dividends"
		b_str = f"{len(pdt_workbook_bookings)} bookings"
		e_str = f"{len(pdt_workbook_expenses)} expenses"
		print(f"Imported {t_str}, {d_str}, {b_str} and {e_str}")

	except PermissionError:
		# File is probably open in Excel
		print(f"{file_path} seems to be in use by another program")
		exit()


def export_worksheet(wb, dataclass_type, iterator):
	"""
	Exports a list of dataclass instances to a worksheet in the given workbook.

	Args:
		wb (Workbook): The openpyxl Workbook to write to.
		dataclass_type (type): The dataclass type (TransactionDetails, etc.)
		iterator (iterable): The collection of dataclass instances to write.
	"""

	# Determine worksheet title based on dataclass type
	if dataclass_type is TransactionDetails:
		ws = wb.create_sheet(title="Transactions")
	elif dataclass_type is DividendDetails:
		ws = wb.create_sheet(title="Dividends")
	elif dataclass_type is BookingDetails:
		ws = wb.create_sheet(title="Bookings")
	elif dataclass_type is ExpenseDetails:
		ws = wb.create_sheet(title="Expenses")
	else:
		raise ValueError(f"Unsupported dataclass type: {dataclass_type.__name__}")

	# Write header row using field names
	column_names = dataclass_type.get_field_names()
	ws.append(column_names)

	# Write data rows
	for item in iterator:
		row = item.get_field_values()
		ws.append(row)


def export_to_pdt(folder_name, file_name):
	"""
	Exports all transaction, dividend, booking, and expense data to a new PDT Excel workbook.
	If a file with the same name already exists, it is renamed as a timestamped backup.

	Args:
		folder_name (str): The folder in which to store the Excel file.
		file_name (str): The desired filename (without .xlsx extension).
	"""
	file_path = os.path.join(folder_name, f"{file_name}.xlsx")

	# If the target file already exists, rename it with a timestamp suffix
	if os.path.exists(file_path):
		creation_time = os.path.getmtime(file_path)
		creation_datetime = datetime.fromtimestamp(creation_time).strftime('%Y%m%dT%H%M%S')
		new_file_path = os.path.join(folder_name, f'{file_name}-{creation_datetime}.xlsx')
		try:
			os.rename(file_path, new_file_path)
		except Exception as e:
			print(f"FATAL: unable to rename file {file_path}. Reason: {e}")
			exit()
		print(f"Saving current PDT file as backup at {new_file_path}")

	print(f"Exporting to {file_path}")

	# Create a new Excel workbook
	wb = Workbook()

	# Remove the default empty sheet added by openpyxl
	wb.remove(wb.active)

	# Merge and sort all data before exporting
	all_transactions = tr_transactions + pdt_workbook_transactions
	all_transactions.sort(key=lambda t: (t.date, t.broker, t.name))
	export_worksheet(wb, TransactionDetails, all_transactions)

	all_dividends = tr_dividends + pdt_workbook_dividends
	all_dividends.sort(key=lambda d: (d.date, d.broker, d.name))
	export_worksheet(wb, DividendDetails, all_dividends)

	all_bookings = tr_bookings + pdt_workbook_bookings
	all_bookings.sort(key=lambda b: (b.date, b.broker))
	export_worksheet(wb, BookingDetails, all_bookings)

	all_expenses = tr_expenses + pdt_workbook_expenses
	all_expenses.sort(key=lambda e: (e.date, e.broker))
	export_worksheet(wb, ExpenseDetails, all_expenses)

	# Save the workbook to disk
	wb.save(file_path)

	# Summary of imported data
	t_str = f"{len(all_transactions)} transactions"
	d_str = f"{len(all_dividends)} dividends"
	b_str = f"{len(all_bookings)} bookings"
	e_str = f"{len(all_bookings)} expenses"
	print(f"Exported {t_str}, {d_str}, {b_str} and {e_str}")


# Main script flow
if __name__ == '__main__':

	# Ensure the Python version is at least 3.8
	# The 'asdict' function from dataclasses guarantees key order only from 3.8+
	v = sys.version_info
	if v < (3, 8):
		print(f"This script requires Python v3.8 and above. You are using v{v.major}.{v.minor}")
		exit()

	# Parse command-line arguments
	parser = argparse.ArgumentParser(description='Get TradeRepublic transactions from the last X days and store them in a file')
	parser.add_argument('--info', action='store_true', help='Show extra info during processing')
	parser.add_argument('phone_no', nargs=1, help='TradeRepublic phone number (international format)')
	parser.add_argument('pin', nargs=1, help='TradeRepublic pin')
	parser.add_argument('-d', '--days', help='Number of last days to include in the file (1 to max 100)')
	parser.add_argument('-f', '--folder', help='Working folder (defaults to current folder)')
	args = parser.parse_args()

	# Set defaults and validate input
	_tr_days = 30
	if not args.days:
		print("No number of days given, defaulting to last 30 days")
	else:
		_tr_days = int(args.days)

	_info_on = args.info

	# Determine working folder
	if not args.folder:
		_folder = "."
	else:
		_folder = args.folder  # Fixed incorrect assignment in original code

	# Read required login details
	_tr_phone = args.phone_no[0]
	_tr_pin = args.pin[0]

	print(f"Using phone={_tr_phone}, pin={_tr_pin}, days={_tr_days}, folder={_folder}")

	# Validate the number of days
	if _tr_days < 1 or _tr_days > 120:
		print("Number of last days should be between 1 and 120")
		exit()

	# Import existing workbook data if the file exists
	import_from_pdt(_folder, pdt_file_name)

	# Compute the timestamp from which to fetch events (00:00 UTC X days ago)
	since_ts = (
		datetime.now(timezone.utc).replace(hour=0, minute=0, second=0, microsecond=0)
		- timedelta(days=_tr_days)
	)

	# Suppress all logging output from third-party modules
	#logging.disable(logging.CRITICAL)

	print("Fetching events from Trade Republic...")

	# Attempt to login and retrieve events
	try:
		# Calculate timestamp for filtering
		_tr_not_before = (datetime.now().astimezone() - timedelta(days=_tr_days)).timestamp()
		print_info(f"not before: {datetime.fromtimestamp(_tr_not_before).strftime('%Y-%m-%d %H:%M:%S')}")

		tl = Timeline(
			login(
				phone_no=_tr_phone,
				pin=_tr_pin,
				waf_token=None
			),
			Path("."),
			_tr_not_before,
			float("inf"), # not_after
			False # store_event_database
		)

		asyncio.run(tl.tl_loop())
		events = tl.events

		# Save the raw event data to a timestamped JSON file for backup/debugging
		dt_str = datetime.now().strftime('%Y%m%dT%H%M%S')
		with open(f"tr_events-{dt_str}.json", "w", encoding="utf-8") as f:
			json.dump(events, f, ensure_ascii=False, indent=4)
		
	# handle exceptions
	except KeyboardInterrupt:
		print("Interrupted by user")
	except Exception as e:
		error_msg = str(e)
		print(f"Unable to login or connect to Trade Republic: {error_msg}", file=sys.stderr)
		
		import traceback
		traceback.print_exc()
		raise

	print(f"Processing {len(events)} events from Trade Republic...")

	# convert to events and transactions
	transactions = []
	for e in events:
		event = Event.from_dict(e)
		# convert an Event to a list of transactions
		txs = list(TransactionExporter().from_event(event))
		transactions.extend(txs)

	# Parse each event into appropriate internal objects
	for tx in transactions:
		read_tr_tx(tx)

	# Check if any new records were parsed
	if (
		len(tr_transactions) > 0
		or len(tr_dividends) > 0
		or len(tr_bookings) > 0
		or len(tr_expenses) > 0
	):

		# Display summary of newly parsed events
		t_str = f"{len(tr_transactions)} new transactions"
		d_str = f"{len(tr_dividends)} new dividends"
		b_str = f"{len(tr_bookings)} new bookings"
		e_str = f"{len(tr_expenses)} new expenses"
		print(f"Added {t_str}, {d_str}, {b_str}, and {e_str} to workbook")

		# Export all parsed and existing events to the PDT workbook
		export_to_pdt(_folder, pdt_file_name)

	else:
		print("No new events found to add to workbook")
